{
  "name": "hms-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:super-admin": "npm run dev -w super-admin -- --port 3001",
    "dev:doctor-portal": "npm run dev -w doctor-portal -- --port 3000",
    "build:super-admin": "npm run build -w super-admin",
    "build:doctor-portal": "npm run build -w doctor-portal",
    "build:all": "npm run build -w super-admin && npm run build -w doctor-portal"
  }
}